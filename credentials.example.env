# =============================================================================
# Agency-OS — Credentials Intake  ("collect in one go")
# =============================================================================
# 1. Copy this file:   cp credentials.example.env credentials.env
# 2. Fill in the values you have (leave the rest blank — blanks are skipped).
# 3. Push them all to Secret Manager in one shot:
#        ./load_credentials.sh [PROJECT_ID]      # defaults to current gcloud project
#
# Notes
# - credentials.env is gitignored — never commit real secrets.
# - Values may contain : / @ $ etc. Wrap in single quotes if so:  KEY='va:lu@e'
# - The loader is idempotent: creates each secret if missing, else adds a version.
# - The NEW OAuth secrets are read at runtime as env vars by
#   control-plane/app/services/oauth_registry.py (it falls back to mock-* if unset).
#   See the "CONSUME" note at the bottom for the deploy wiring to inject them.
# -----------------------------------------------------------------------------

# --- Platform secrets (ALREADY set in prod; fill ONLY to rotate) -------------
# secret: aos-database-url
DATABASE_URL=
# secret: aos-worker-database-url
WORKER_DATABASE_URL=
# secret: aos-operator-token        (bearer token gating the operator API)
OPERATOR_TOKEN=
# secret: whatsapp-app-secret       (Meta App Secret — webhook HMAC)
WHATSAPP_APP_SECRET=
# secret: whatsapp-verify-token
WHATSAPP_VERIFY_TOKEN=
# secret: aos-oauth-state-secret    (HMAC key signing the OAuth state token;
#   generate once: openssl rand -base64 32. REQUIRED in production — the app now
#   refuses to boot with ENV=production if this is unset, so state tokens can never
#   fall back to the forgeable hardcoded default.)
SECRET_KEY=

# --- Google Ads / Google OAuth (NEW — replaces the mock-* client id) ---------
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
# secret: google-ads-client-id        -> env GOOGLE_ADS_CLIENT_ID
GOOGLE_ADS_CLIENT_ID=
# secret: google-ads-client-secret    -> env GOOGLE_ADS_CLIENT_SECRET
GOOGLE_ADS_CLIENT_SECRET=
# Google Ads API developer token (Ads account -> Tools -> API Center) — issue #169
# secret: google-ads-developer-token
GOOGLE_ADS_DEVELOPER_TOKEN=

# --- Meta / Facebook Ads OAuth (NEW) -----------------------------------------
# developers.facebook.com -> App -> Settings -> Basic (App ID / App Secret)
# secret: meta-ads-client-id          -> env META_ADS_CLIENT_ID
META_ADS_CLIENT_ID=
# secret: meta-ads-client-secret      -> env META_ADS_CLIENT_SECRET
META_ADS_CLIENT_SECRET=

# --- Shopify OAuth (NEW) -----------------------------------------------------
# Shopify Partner dashboard -> your app -> Client credentials (API key / secret)
# secret: shopify-client-id           -> env SHOPIFY_CLIENT_ID
SHOPIFY_CLIENT_ID=
# secret: shopify-client-secret       -> env SHOPIFY_CLIENT_SECRET
SHOPIFY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Per-brand connection tokens (access/refresh) are NOT collected here — they are
# obtained at runtime via the OAuth flow (POST /api/v1/onboarding/oauth/... in
# control-plane/app/routers/onboarding.py) and stored per tenant/brand in Secret
# Manager automatically.
#
# CONSUME (follow-up — do AFTER the secrets exist + onboarding code is on main):
#   Add the NEW secrets to .github/workflows/deploy.yml --set-secrets so they
#   reach the runtime as the env vars oauth_registry.py reads, e.g.:
#     GOOGLE_ADS_CLIENT_ID=google-ads-client-id:latest,
#     GOOGLE_ADS_CLIENT_SECRET=google-ads-client-secret:latest,
#     META_ADS_CLIENT_ID=meta-ads-client-id:latest,
#     META_ADS_CLIENT_SECRET=meta-ads-client-secret:latest,
#     SHOPIFY_CLIENT_ID=shopify-client-id:latest,
#     SHOPIFY_CLIENT_SECRET=shopify-client-secret:latest
#   (Do NOT add a secret to --set-secrets before it exists, or the deploy fails.)
# =============================================================================
